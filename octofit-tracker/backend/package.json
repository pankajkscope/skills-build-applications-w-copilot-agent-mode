{
  "name": "octofit-tracker-backend",
  "version": "1.0.0",
  "private": true,
  "description": "OctoFit Tracker backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "ts-node-dev --transpile-only --exit-child src/scripts/seed.ts",
    "validate:routes": "bash scripts/validate-routes.sh"
  },
  "dependencies": {
    "express": "^5.2.1",
    "mongoose": "^9.7.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
